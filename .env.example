# Supabase Configuration (service-role key for backend)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Legacy name still supported:
# SUPABASE_KEY=your-service-role-key-here

# Optional for local Vite-only testing against a deployed backend.
# Leave blank in Vercel/production so the frontend uses /api.
VITE_ENQUIRY_API_BASE_URL=

# SMTP Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
RECEIVER_EMAIL=He_jani2523@yahoo.in
# Optional: send every enquiry immediately as well as in the 4-hour digest.
SEND_IMMEDIATE_ENQUIRY_EMAIL=false

# (Optional) Cron security secret
CRON_SECRET=your-random-secret-here
